{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/[...].ts": {
      "includeFiles": [
        "public/**",
        "dist/public/**"
      ]
    }
  },
  "builds": [
    {
      "src": "api/[...].ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/[...].ts"
    }
  ]
}